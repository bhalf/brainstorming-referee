# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Required for AI-generated interventions, embeddings, and transcription
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Backend API ───────────────────────────────────────────────────────────────
# Required for all HTTP API calls (session CRUD, join, export, etc.)
# Points to the FastAPI backend service
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Required for data persistence and realtime sync
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── LiveKit ──────────────────────────────────────────────────────────────────
# Required for video conferencing
# Get from: https://cloud.livekit.io → Project Settings
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...

# ─── Optional ─────────────────────────────────────────────────────────────────
# Secret for cron job authentication (e.g., session cleanup)
# CRON_SECRET=your-random-secret
